# ── Ziwa · configuration ─────────────────────────────────────────────
# Copier ce fichier en `.env` puis renseigner la clé. Ne JAMAIS committer le .env réel.

# Clé API Anthropic — https://console.anthropic.com/  (sk-ant-...)
# Utilisée uniquement côté serveur pour l'analyse IA. Jamais exposée au navigateur.
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modèle Claude pour l'analyse des événements (défaut: Sonnet courant).
CLAUDE_MODEL=claude-sonnet-4-6

# Port HTTP du backend (défaut 3000).
PORT=3000
